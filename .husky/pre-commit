npx lint-staged
pnpm build
pnpm typecheck

# If config-schemas.ts was modified, verify JSON Schemas are up-to-date
if git diff --cached --name-only | grep -q 'packages/core/src/config-schemas.ts'; then
  echo "config-schemas.ts changed — checking JSON Schemas are up-to-date..."
  pnpm --filter cyrus-core generate:json-schema
  if ! git diff --quiet packages/core/schemas/; then
    echo ""
    echo "ERROR: JSON Schema files are out of date."
    echo "The generate:json-schema script produced changes not staged for commit."
    echo "Please stage the updated schemas: git add packages/core/schemas/"
    exit 1
  fi
fi
