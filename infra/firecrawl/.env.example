PORT=3002
HOST=0.0.0.0
NUM_WORKERS_PER_QUEUE=4
PLAYWRIGHT_MICROSERVICE_URL=http://playwright-service:3000/scrape
USE_DB_AUTHENTICATION=false
REDIS_URL=redis://firecrawl-redis:6379
REDIS_RATE_LIMIT_URL=redis://firecrawl-redis:6379
MAX_RAM=0.8
MAX_CPU=0.8
TEST_API_KEY=fc-brilliantio-local
BULL_AUTH_KEY=your-random-string-here

# DataImpulse residential rotating proxy — required for scraping sites that block datacenter IPs
# Residential IPs rotate automatically per request (~$1/GB)
# Format: http://<username>:<password>@gw.dataimpulse.com:823
PROXY_SERVER=http://your-dataimpulse-username:your-dataimpulse-password@gw.dataimpulse.com:823
PROXY_USERNAME=your-dataimpulse-username
PROXY_PASSWORD=your-dataimpulse-password
